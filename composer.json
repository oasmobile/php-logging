{
    "name"             : "oasis/logging",
    "description"      : "Wrapper of monolog/monolog. Should be easier to use/configure than monolog",
    "minimum-stability": "stable",
    "license"          : "MIT",
    "authors"          : [
        {
            "name" : "Minhao Zhang",
            "email": "minhao.zhang@qq.com"
        }
    ],
    "require"          : {
        "php"                                  : ">=8.5",
        "monolog/monolog"                      : "^3.0",
        "bramus/monolog-colored-line-formatter": "^3.0",
        "oasis/utils"                          : "^3.1"
    },
    "require-dev"      : {
        "phpunit/phpunit"      : "^13.0",
        "giorgiosironi/eris"   : "^1.1",
        "symfony/console"      : "^8.0",
        "symfony/finder"       : "^8.0"
    },
    "suggest"          : {
        "symfony/console"   : "^8.0",
        "oasis/aws-wrappers": "^2.7"
    },
    "autoload"         : {
        "psr-4": {
            "Oasis\\Mlib\\Logging\\": "src/"
        },
        "files": [
            "src/MLogging.inc.php"
        ]
    }
}
